## 配置设备平台
### lite: 酷狗概念版, 默认为手机版
platform='lite'

## 服务端口 (可选)
PORT='3000'

## HTTP 代理地址 (可选)
KUGOU_API_PROXY=''

## 设备id(可选，建议固定 )
## KUGOU_API_GUID 建议为 uuidv4
## KUGOU_API_DEV 建议长度为 10 位的字符串
## MAC地址
KUGOU_API_GUID='3f7e2b1c-8a4d-4f5e-9b2c-6d1e8f3a7b5d'
KUGOU_API_DEV='xK9mP2nR4q'
KUGOU_API_MAC='5E2A8FC16D4B'

